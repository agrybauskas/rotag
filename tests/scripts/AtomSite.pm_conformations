#!/usr/bin/perl

use strict;
use warnings;

use Data::Dumper;

use AtomSite;
use SidechainModels qw( rotation_only_new );

$Data::Dumper::Indent = 1;
$Data::Dumper::Sortkeys = 1;

#
# Unit test: AtomSite::set_conformations
# Example: ./AtomSite.pm_conformations structure.dump
#

my ( $pdbx_dump_file ) = @ARGV;

my $atoms;
open( my $fh, "<", $pdbx_dump_file );
while( <$fh> ) {
    $atoms .= "$_" ;
}
close( $fh );
$atoms = eval( $atoms );

my $atom_site = AtomSite->new( { 'atoms' => $atoms } );
$atom_site->set_conformations( \&rotation_only_new );

for my $atom_id ( sort { $a <=> $b } keys %{ $atom_site->get_conformations } ) {
    print Dumper $atom_site->get_conformations->{$atom_id};
}
